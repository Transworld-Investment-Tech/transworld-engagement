# Copy this file to  deploy.config  and fill in the blanks.
# deploy.config is gitignored and is NEVER pushed or zipped with your secrets.

# --- Supabase (powers your local `npm run dev`) ---------------------------
SUPABASE_URL="https://brmyrigncgnqlisvikgz.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""     # Supabase ▸ Settings ▸ API ▸ service_role (secret)

# --- Auth -----------------------------------------------------------------
JWT_SECRET=""                    # generate with:  openssl rand -base64 48

# --- Email (Resend) — used by Greetings in v1.1 --------------------------
RESEND_API_KEY=""
MAIL_FROM="Transworld <noreply@transworldltd.com.ng>"

# --- Greetings reminder cron (v1.1) --------------------------------------
CRON_SECRET=""                  # any long random string; Vercel sends it as a Bearer token to the cron route. Generate with: openssl rand -base64 32
GREETINGS_REMINDER_TO=""        # who gets the morning "birthdays to release" email, e.g. "okezie@transworldltd.com.ng"  (comma-separate for several)

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://transworld-engagement.vercel.app"

# --- GitHub ---------------------------------------------------------------
GIT_REMOTE="https://github.com/Transworld-Investment-Tech/transworld-engagement.git"
GIT_NAME="Okezie Ofoegbu"
GIT_EMAIL="okezie@transworldltd.com.ng"
