# --- Supabase ---
# Project URL and the SERVICE ROLE key (server-side only; never expose to the browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string

# --- Email (Resend) ---
RESEND_API_KEY=re_your_key
MAIL_FROM="Transworld <noreply@transworldltd.com.ng>"

# --- Greetings reminder cron ---
# Secures /api/cron/birthday-reminder. Vercel sends it as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=replace-with-a-long-random-string
# Who receives the morning "birthdays to release" reminder (comma-separate for several).
GREETINGS_REMINDER_TO=okezie@transworldltd.com.ng

# --- App ---
# Public base URL of this app (used for signing links later)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Research reports (added v1.8; read from Phase 1 onward) ---
# Anthropic API key for parsing uploaded research PDFs (model claude-sonnet-4-6).
ANTHROPIC_API_KEY=sk-ant-your-key
# Resend webhook signing secret (whsec_...) — verifies delivery/open/bounce events.
RESEND_WEBHOOK_SECRET=whsec_your_secret
# Authenticates the internal Puppeteer print route so it can render drafts.
# Generate with: openssl rand -hex 32
PRINT_TOKEN=replace-with-32-byte-hex
# Sparticuz Chromium runtime hint for research-PDF rendering. MUST be set in the
# Vercel dashboard specifically — Sparticuz reads it at module-load, before app
# code runs, so setting it in code is too late.
AWS_LAMBDA_JS_RUNTIME=nodejs22.x
